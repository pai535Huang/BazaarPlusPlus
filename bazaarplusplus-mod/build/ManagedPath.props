<Project>
  <!-- Keep game assembly and game-root discovery identical for every production and
       test project. Callers may override either property explicitly with -p. -->
  <PropertyGroup>
    <LinuxSteamGameDefault>$(HOME)/.local/share/Steam/steamapps/common/The Bazaar</LinuxSteamGameDefault>
    <LinuxSteamGameLegacy>$(HOME)/.steam/steam/steamapps/common/The Bazaar</LinuxSteamGameLegacy>
    <LinuxSteamGameFlatpak>$(HOME)/.var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps/common/The Bazaar</LinuxSteamGameFlatpak>
    <LinuxSteamManagedDefault>$(LinuxSteamGameDefault)/TheBazaar_Data/Managed</LinuxSteamManagedDefault>
    <LinuxSteamManagedLegacy>$(LinuxSteamGameLegacy)/TheBazaar_Data/Managed</LinuxSteamManagedLegacy>
    <LinuxSteamManagedFlatpak>$(LinuxSteamGameFlatpak)/TheBazaar_Data/Managed</LinuxSteamManagedFlatpak>
  </PropertyGroup>

  <PropertyGroup Condition="'$(ManagedPath)' == '' and Exists('$(LinuxSteamManagedDefault)/Assembly-CSharp.dll')">
    <ManagedPath>$(LinuxSteamManagedDefault)</ManagedPath>
    <GamePath>$(LinuxSteamGameDefault)</GamePath>
  </PropertyGroup>
  <PropertyGroup Condition="'$(ManagedPath)' == '' and Exists('$(LinuxSteamManagedLegacy)/Assembly-CSharp.dll')">
    <ManagedPath>$(LinuxSteamManagedLegacy)</ManagedPath>
    <GamePath>$(LinuxSteamGameLegacy)</GamePath>
  </PropertyGroup>
  <PropertyGroup Condition="'$(ManagedPath)' == '' and Exists('$(LinuxSteamManagedFlatpak)/Assembly-CSharp.dll')">
    <ManagedPath>$(LinuxSteamManagedFlatpak)</ManagedPath>
    <GamePath>$(LinuxSteamGameFlatpak)</GamePath>
  </PropertyGroup>
</Project>

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BazaarPlusPlus",
  "version": "4.2.0",
  "identifier": "com.bazaarplusplus.bppinstaller",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:14207",
    "beforeBuildCommand": "env TAURI_ENV_PLATFORM=linux npm run prebuild-check && npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "BazaarPlusPlus",
        "width": 1000,
        "height": 720,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  },
  "plugins": {}
}

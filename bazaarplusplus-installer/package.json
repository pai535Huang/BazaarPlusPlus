{
  "name": "bppinstaller",
  "version": "4.2.0",
  "description": "BazaarPlusPlus Desktop App",
  "type": "module",
  "scripts": {
    "generate:bindings": "node scripts/generate-bindings.mjs",
    "dev": "npm run generate:bindings && vite dev",
    "version:sync": "node scripts/version-sync.mjs",
    "prebuild-check": "node scripts/prebuild-check.mjs",
    "build": "npm run generate:bindings && vite build",
    "preview": "vite preview",
    "test": "npm run generate:bindings && npm run test:rust && npm run test:unit",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"*.json\" \"src/**/*.{ts,tsx,html}\" \"scripts/**/*.mjs\" \"src-tauri/*.json\" \"src-tauri/capabilities/**/*.json\" \"vite.config.ts\"",
    "format:check": "prettier --check \"*.json\" \"src/**/*.{ts,tsx,html}\" \"scripts/**/*.mjs\" \"src-tauri/*.json\" \"src-tauri/capabilities/**/*.json\" \"vite.config.ts\"",
    "check": "npm run generate:bindings && tsc --noEmit",
    "check:watch": "npm run generate:bindings && tsc --noEmit --watch",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
